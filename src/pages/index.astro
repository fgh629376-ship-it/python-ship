---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const zhPosts = allPosts.filter(p => (p.data.lang || 'zh') === 'zh');
const pythonPosts = zhPosts.filter(p => p.data.category === 'python');
const solarPosts = zhPosts.filter(p => p.data.category === 'solar');
const algoPosts = zhPosts.filter(p => p.data.category === 'algorithm');
const totalPosts = zhPosts.length;
const latestPosts = allPosts.slice(0, 18);
---

<!doctype html>
<html lang="zh">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      /* ===== CYBERPUNK VARIABLES ===== */
      :root {
        --neon-gold: #f59e0b;
        --neon-orange: #f97316;
        --neon-green: #00ff88;
        --neon-cyan: #00f0ff;
        --neon-purple: #bf5af2;
        --neon-pink: #ff2d78;
        --cyber-bg: #0a0e17;
        --cyber-card: rgba(15, 20, 35, 0.85);
        --cyber-border: rgba(0, 240, 255, 0.15);
        --grid-color: rgba(0, 240, 255, 0.03);
      }

      /* ===== HERO ===== */
      .hero {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 4rem 2rem;
        position: relative;
        overflow: hidden;
        background: var(--cyber-bg);
      }

      /* Animated grid background */
      .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(var(--grid-color) 1px, transparent 1px),
          linear-gradient(90deg, var(--grid-color) 1px, transparent 1px);
        background-size: 60px 60px;
        animation: gridMove 20s linear infinite;
        mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
        -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 70%);
      }

      /* Neon glow orbs */
      .hero::after {
        content: '';
        position: absolute;
        inset: 0;
        background:
          radial-gradient(circle at 20% 30%, rgba(245, 158, 11, 0.15) 0%, transparent 40%),
          radial-gradient(circle at 80% 20%, rgba(0, 240, 255, 0.1) 0%, transparent 35%),
          radial-gradient(circle at 60% 70%, rgba(0, 255, 136, 0.08) 0%, transparent 40%),
          radial-gradient(circle at 30% 80%, rgba(191, 90, 242, 0.06) 0%, transparent 35%);
        pointer-events: none;
        animation: orbPulse 8s ease-in-out infinite alternate;
      }

      /* Scanline overlay */
      .scanlines {
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(
          0deg,
          transparent,
          transparent 2px,
          rgba(0, 0, 0, 0.03) 2px,
          rgba(0, 0, 0, 0.03) 4px
        );
        pointer-events: none;
        z-index: 1;
      }

      .hero-content {
        position: relative;
        z-index: 2;
      }

      /* Glitch badge */
      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.4rem 1.2rem;
        border-radius: 0;
        border: 1px solid var(--neon-cyan);
        background: rgba(0, 240, 255, 0.05);
        color: var(--neon-cyan);
        font-size: 0.78rem;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        margin-bottom: 2.5rem;
        animation: fadeInUp 0.8s ease, borderFlicker 4s infinite;
        clip-path: polygon(8px 0, 100% 0, calc(100% - 8px) 100%, 0 100%);
      }
      .hero-badge .pulse {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--neon-gold);
        box-shadow: 0 0 12px var(--neon-gold), 0 0 24px rgba(245, 158, 11, 0.3);
        animation: pulse 1.5s infinite;
      }

      /* Glitch title */
      .hero h1 {
        font-size: clamp(3.5rem, 10vw, 7rem);
        font-weight: 900;
        letter-spacing: -0.02em;
        line-height: 1;
        margin: 0 0 1.5rem;
        animation: fadeInUp 0.8s ease 0.1s both;
        position: relative;
      }
      .hero h1 .gradient {
        background: linear-gradient(135deg, var(--neon-gold) 0%, var(--neon-orange) 25%, var(--neon-green) 60%, var(--neon-cyan) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        filter: drop-shadow(0 0 30px rgba(245, 158, 11, 0.3));
        animation: glitchText 8s infinite;
      }

      .hero .tagline {
        font-size: clamp(1.1rem, 3vw, 1.4rem);
        color: rgba(226, 232, 240, 0.7);
        margin: 0 0 0.8rem;
        max-width: 650px;
        line-height: 1.7;
        animation: fadeInUp 0.8s ease 0.2s both;
      }
      .hero .tagline strong {
        color: var(--neon-gold);
        text-shadow: 0 0 20px rgba(245, 158, 11, 0.3);
      }
      .hero .sub {
        font-size: 0.82rem;
        color: var(--neon-cyan);
        opacity: 0.5;
        margin: 0 0 3rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        animation: fadeInUp 0.8s ease 0.3s both;
      }

      /* Neon buttons */
      .hero-actions {
        display: flex;
        justify-content: center;
        gap: 1.2rem;
        animation: fadeInUp 0.8s ease 0.4s both;
      }
      .btn-neon {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 2.5rem;
        border: 1px solid var(--neon-gold);
        background: rgba(245, 158, 11, 0.1);
        color: var(--neon-gold);
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        letter-spacing: 0.05em;
        transition: all 0.3s;
        font-family: inherit;
        clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
        cursor: pointer;
      }
      .btn-neon:hover {
        background: var(--neon-gold);
        color: #0a0e17;
        box-shadow: 0 0 30px rgba(245, 158, 11, 0.4), inset 0 0 30px rgba(245, 158, 11, 0.1);
        text-decoration: none;
      }
      .btn-ghost {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.85rem 2.5rem;
        border: 1px solid var(--neon-cyan);
        background: transparent;
        color: var(--neon-cyan);
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        letter-spacing: 0.05em;
        transition: all 0.3s;
        clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
      }
      .btn-ghost:hover {
        background: rgba(0, 240, 255, 0.1);
        box-shadow: 0 0 20px rgba(0, 240, 255, 0.2);
        text-decoration: none;
      }

      /* ===== STATS — Hologram style ===== */
      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        max-width: 800px;
        margin: -4rem auto 5rem;
        padding: 0 2rem;
        position: relative;
        z-index: 3;
      }
      .stat {
        text-align: center;
        padding: 2rem 1rem;
        border-radius: 2px;
        background: var(--cyber-card);
        border: 1px solid var(--cyber-border);
        backdrop-filter: blur(10px);
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
      }
      .stat::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, transparent, var(--neon-cyan), transparent);
        opacity: 0.5;
      }
      .stat:hover {
        border-color: var(--neon-cyan);
        box-shadow: 0 0 20px rgba(0, 240, 255, 0.1), inset 0 0 20px rgba(0, 240, 255, 0.03);
        transform: translateY(-4px);
      }
      .stat-number {
        font-size: 3rem;
        font-weight: 900;
        color: var(--neon-gold);
        text-shadow: 0 0 20px rgba(245, 158, 11, 0.5);
        line-height: 1;
        margin-bottom: 0.5rem;
      }
      .stat-label {
        font-size: 0.78rem;
        color: var(--neon-cyan);
        letter-spacing: 0.1em;
        text-transform: uppercase;
        opacity: 0.7;
      }

      /* ===== SECTIONS ===== */
      .section {
        max-width: 1000px;
        margin: 0 auto;
        padding: 0 2rem 6rem;
      }
      .section-header {
        text-align: center;
        margin-bottom: 3rem;
      }
      .section-header h2 {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 900;
        color: var(--text);
        border: none;
        padding: 0;
        margin: 0 0 0.8rem;
        text-shadow: 0 0 40px rgba(245, 158, 11, 0.15);
      }
      .section-header p {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin: 0;
      }

      /* ===== FEATURES — Cyberpunk cards ===== */
      .features {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
        margin-bottom: 6rem;
      }
      .feature-card {
        padding: 2.5rem 2rem;
        border-radius: 2px;
        background: var(--cyber-card);
        border: 1px solid var(--cyber-border);
        backdrop-filter: blur(10px);
        transition: all 0.4s;
        position: relative;
        overflow: hidden;
      }
      /* Top neon bar */
      .feature-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: var(--card-glow);
        opacity: 0.6;
        transition: opacity 0.3s;
      }
      /* Corner decoration */
      .feature-card::after {
        content: '';
        position: absolute;
        bottom: 0; right: 0;
        width: 40px; height: 40px;
        border-right: 2px solid var(--card-glow);
        border-bottom: 2px solid var(--card-glow);
        opacity: 0;
        transition: opacity 0.3s;
      }
      .feature-card:hover {
        border-color: var(--card-glow);
        box-shadow: 0 0 30px color-mix(in srgb, var(--card-glow) 20%, transparent);
        transform: translateY(-6px);
      }
      .feature-card:hover::before { opacity: 1; }
      .feature-card:hover::after { opacity: 0.5; }

      .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1.2rem;
        display: block;
        filter: drop-shadow(0 0 10px var(--card-glow));
      }
      .feature-card h3 {
        font-size: 1.15rem;
        color: var(--text);
        margin: 0 0 0.6rem;
      }
      .feature-card p {
        color: var(--text-muted);
        font-size: 0.88rem;
        line-height: 1.7;
        margin: 0;
      }
      a.feature-card { text-decoration: none; color: inherit; cursor: pointer; }
      a.feature-card:hover { text-decoration: none; color: inherit; }
      .card-arrow {
        display: inline-block;
        margin-top: 1rem;
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--card-glow);
        opacity: 0;
        transform: translateX(-10px);
        transition: all 0.3s;
      }
      .feature-card:hover .card-arrow { opacity: 1; transform: translateX(0); }

      .feature-card.python { --card-glow: var(--neon-green); }
      .feature-card.solar  { --card-glow: var(--neon-gold); }
      .feature-card.auto   { --card-glow: var(--neon-cyan); }
      .feature-card.open   { --card-glow: var(--neon-purple); }

      /* ===== POSTS GRID ===== */
      .posts-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
      .posts-grid .post-item {
        padding: 1.8rem;
        border-radius: 2px;
        background: var(--cyber-card);
        border: 1px solid var(--cyber-border);
        backdrop-filter: blur(10px);
        text-decoration: none;
        display: flex;
        flex-direction: column;
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
      }
      .posts-grid .post-item::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 3px; height: 0;
        background: var(--neon-gold);
        transition: height 0.3s;
      }
      .posts-grid .post-item:hover {
        border-color: rgba(245, 158, 11, 0.3);
        box-shadow: 0 0 20px rgba(245, 158, 11, 0.08);
        transform: translateY(-3px);
        text-decoration: none;
      }
      .posts-grid .post-item:hover::before { height: 100%; }

      .post-item .post-cat {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.15rem 0.6rem;
        border-radius: 0;
        font-size: 0.7rem;
        font-weight: 700;
        margin-bottom: 0.8rem;
        width: fit-content;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }
      .post-cat.python {
        background: rgba(0, 255, 136, 0.08);
        color: var(--neon-green);
        border: 1px solid rgba(0, 255, 136, 0.2);
      }
      .post-cat.solar {
        background: rgba(245, 158, 11, 0.08);
        color: var(--neon-gold);
        border: 1px solid rgba(245, 158, 11, 0.2);
      }
      .post-cat.algorithm {
        background: rgba(191, 90, 242, 0.08);
        color: var(--neon-purple);
        border: 1px solid rgba(191, 90, 242, 0.2);
      }
      .post-item h3 {
        font-size: 1rem;
        color: var(--text);
        margin: 0 0 0.5rem;
        line-height: 1.4;
      }
      .post-item:hover h3 { color: var(--neon-gold); }
      .post-item .post-desc {
        font-size: 0.83rem;
        color: var(--text-muted);
        margin: 0 0 1rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        flex: 1;
      }
      .post-item .post-meta {
        font-size: 0.75rem;
        color: var(--neon-cyan);
        opacity: 0.5;
        letter-spacing: 0.05em;
      }
      .view-all {
        text-align: center;
        margin-top: 3rem;
      }

      /* ===== ABOUT — Terminal style ===== */
      .about-section {
        max-width: 800px;
        margin: 4rem auto 0;
        padding: 0 1.5rem;
      }
      .about-inner {
        background: var(--cyber-card);
        border: 1px solid var(--cyber-border);
        border-radius: 2px;
        padding: 2.5rem;
        display: flex;
        gap: 2rem;
        align-items: flex-start;
        position: relative;
      }
      .about-inner::before {
        content: '// ABOUT.md';
        position: absolute;
        top: -10px; left: 16px;
        background: var(--cyber-bg);
        padding: 0 8px;
        font-size: 0.7rem;
        color: var(--neon-cyan);
        letter-spacing: 0.1em;
      }
      .about-avatar {
        font-size: 3rem;
        flex-shrink: 0;
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(0,255,136,0.08), rgba(0,240,255,0.08));
        border-radius: 0;
        border: 1px solid rgba(0, 255, 136, 0.2);
        clip-path: polygon(10px 0, 100% 0, calc(100% - 10px) 100%, 0 100%);
      }
      .about-content h2 {
        font-size: 1.3rem;
        color: var(--neon-green);
        margin: 0 0 1rem;
        text-shadow: 0 0 15px rgba(0, 255, 136, 0.3);
      }
      .about-intro {
        color: var(--text-muted);
        font-size: 0.9rem;
        line-height: 1.8;
        margin: 0;
      }
      .about-intro strong {
        color: var(--neon-gold);
        font-weight: 600;
      }
      .about-signature {
        margin-top: 1.5rem;
        padding-top: 1rem;
        border-top: 1px solid var(--cyber-border);
        color: var(--neon-cyan);
        font-size: 0.8rem;
        font-style: normal;
        letter-spacing: 0.05em;
        opacity: 0.7;
      }
      .sig-dash { color: var(--neon-gold); margin-right: 0.5rem; }

      /* Philosophy */
      .philosophy-section {
        max-width: 900px;
        margin: 3rem auto 0;
        padding: 0 1.5rem;
      }
      .philosophy-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.2rem;
      }
      .phi-card {
        background: var(--cyber-card);
        border: 1px solid var(--cyber-border);
        border-radius: 2px;
        padding: 1.5rem;
        text-align: center;
        transition: all 0.3s;
        position: relative;
      }
      .phi-card:hover {
        border-color: var(--neon-cyan);
        box-shadow: 0 0 20px rgba(0, 240, 255, 0.1);
        transform: translateY(-4px);
      }
      .phi-icon { font-size: 2rem; display: block; margin-bottom: 0.8rem; }
      .phi-card h3 { font-size: 0.95rem; color: var(--text); margin: 0 0 0.6rem; }
      .phi-card p { color: var(--text-muted); font-size: 0.8rem; line-height: 1.7; margin: 0; }

      /* ===== CTA ===== */
      .cta-section {
        max-width: 700px;
        margin: 0 auto;
        text-align: center;
        padding: 5rem 2rem 6rem;
        position: relative;
      }
      .cta-section h2 {
        font-size: clamp(1.5rem, 4vw, 2rem);
        color: var(--text);
        border: none;
        padding: 0;
        margin: 0 0 1rem;
      }
      .cta-section p {
        color: var(--text-muted);
        margin: 0 0 2rem;
      }

      /* ===== ANIMATIONS ===== */
      @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
      }
      @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.4; transform: scale(1.8); }
      }
      @keyframes gridMove {
        from { transform: translate(0, 0); }
        to { transform: translate(60px, 60px); }
      }
      @keyframes orbPulse {
        from { opacity: 0.8; }
        to { opacity: 1.2; }
      }
      @keyframes borderFlicker {
        0%, 95%, 100% { border-color: var(--neon-cyan); }
        96% { border-color: transparent; }
        97% { border-color: var(--neon-cyan); }
        98% { border-color: transparent; }
      }
      @keyframes glitchText {
        0%, 92%, 100% { filter: drop-shadow(0 0 30px rgba(245, 158, 11, 0.3)); }
        93% { filter: drop-shadow(2px 0 30px rgba(0, 240, 255, 0.5)) drop-shadow(-2px 0 rgba(255, 45, 120, 0.5)); }
        94% { filter: drop-shadow(-1px 0 30px rgba(0, 255, 136, 0.5)); }
        95% { filter: drop-shadow(0 0 30px rgba(245, 158, 11, 0.3)); }
      }
      @keyframes typing {
        from { width: 0; }
        to { width: 100%; }
      }

      /* ===== SCROLL REVEAL ===== */
      .reveal {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* ===== RESPONSIVE ===== */
      @media (max-width: 768px) {
        .hero { min-height: 80vh; padding: 3rem 1.5rem; }
        .features { grid-template-columns: 1fr; }
        .posts-grid { grid-template-columns: 1fr; }
        .stats { grid-template-columns: repeat(3, 1fr); gap: 0.8rem; margin-top: -2rem; }
        .stat { padding: 1.2rem 0.5rem; }
        .stat-number { font-size: 2rem; }
        .hero-actions { flex-direction: column; align-items: center; }
        .about-inner { flex-direction: column; align-items: center; text-align: center; padding: 2rem 1.5rem; }
        .philosophy-grid { grid-template-columns: 1fr; }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- HERO -->
    <section class="hero">
      <div class="scanlines"></div>
      <div class="hero-content">
        <div class="hero-badge">
          <span class="pulse"></span>
          <span data-i18n="heroBadge">LIVE · 每晚 22:00 自动发布</span>
        </div>
        <h1>
          <span class="gradient">Python Ship</span>
        </h1>
        <p class="tagline" data-i18n-html="heroTaglineNew">
          从 <strong>Python 语法</strong>到<strong>光伏功率预测</strong><br />
          用代码驱动清洁能源的未来
        </p>
        <p class="sub" data-i18n="heroSubNew">AI_GENERATED · TECH_DEEP_DIVE · RUNNABLE_CODE</p>
        <div class="hero-actions">
          <a href="/blog" class="btn-neon" data-i18n="heroBtnBlog">⚡ 浏览全部文章</a>
          <a href="https://github.com/fgh629376-ship-it/python-ship" target="_blank" class="btn-ghost">
            &lt;/&gt; GitHub
          </a>
        </div>
      </div>
    </section>

    <!-- STATS -->
    <div class="stats reveal">
      <div class="stat">
        <div class="stat-number">{totalPosts}</div>
        <div class="stat-label" data-i18n="statArticles">ARTICLES</div>
      </div>
      <div class="stat">
        <div class="stat-number">{pythonPosts.length}</div>
        <div class="stat-label" data-i18n="statPython">PYTHON</div>
      </div>
      <div class="stat">
        <div class="stat-number">{solarPosts.length + algoPosts.length}</div>
        <div class="stat-label" data-i18n="statSolar">SOLAR & ALGO</div>
      </div>
    </div>

    <!-- FEATURES -->
    <section class="section">
      <div class="section-header reveal">
        <h2 data-i18n="sectionFeatureTitle">// 核心方向</h2>
        <p data-i18n="sectionFeatureDesc">Python 工程能力 × 光伏领域知识，双线并进</p>
      </div>
      <div class="features">
        <a href="/blog?cat=python" class="feature-card python reveal">
          <span class="feature-icon">🐍</span>
          <h3 data-i18n="featurePythonTitle">Python 深度教程</h3>
          <p data-i18n="featurePythonDesc">asyncio、装饰器、生成器、dataclass、Pydantic —— 从语法糖到工业级用法，每篇附完整可运行代码</p>
          <span class="card-arrow" data-i18n="cardArrowPython">→ ENTER</span>
        </a>
