    <div class="chapter-list">
      {chapters.map(ch => (
        <div class="chapter" data-ch={ch.id}>
          <div class="chapter-head" onclick={`this.parentElement.classList.toggle('open')`}>
            <span class="arrow">▶</span>
            <span class="status">{ch.status}</span>
