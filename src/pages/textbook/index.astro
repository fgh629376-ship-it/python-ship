---

<!doctype html>
<html lang="zh">
<head>
  <BaseHead title="教材精读 | Python Ship" description="系统性学习预测相关教材，输出精读笔记与思维训练" />
  <meta name="color-scheme" content="dark" />
  <style>
    .catalog-container {
      max-width: 960px;
      margin: 0 auto;
      padding: 2rem 1.5rem 4rem;
    }
    .catalog-hero {
      text-align: center;
      padding: 2rem 0 2.5rem;
    }
    .catalog-hero h1 {
      font-size: 2.5rem;
      font-weight: 800;
      background: linear-gradient(135deg, #4ade80, #22d3ee);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .catalog-hero p {
      color: #94a3b8;
      margin-top: 0.5rem;
      font-size: 1.05rem;
    }
    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-bottom: 2rem;
      flex-wrap: wrap;
    }
    .stat-item {
      text-align: center;
    }
    .stat-num {
      font-size: 1.8rem;
      font-weight: 800;
      color: #4ade80;
    }
    .stat-label {
      font-size: 0.85rem;
      color: #64748b;
    }
    .book-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .book-card {
      background: #1a1d2e;
      border-radius: 12px;
      padding: 1.5rem;
      border-top: 3px solid var(--accent);
      transition: transform 0.2s, box-shadow 0.2s;
      text-decoration: none;
      color: inherit;
      display: block;
    }
    .book-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 20px rgba(74, 222, 128, 0.1);
    }
    .book-card.queued {
      opacity: 0.6;
      pointer-events: none;
    }
    .book-header {
      display: flex;
      align-items: flex-start;
      gap: 1rem;
      margin-bottom: 0.8rem;
    }
    .book-emoji {
      font-size: 2rem;
      flex-shrink: 0;
    }
    .book-info { flex: 1; }
    .book-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #f1f5f9;
      margin-bottom: 0.2rem;
    }
    .book-title-en {
      font-size: 0.85rem;
      color: #64748b;
      font-style: italic;
    }
    .book-author {
      font-size: 0.85rem;
      color: #94a3b8;
    }
    .book-desc {
      font-size: 0.9rem;
      color: #94a3b8;
      line-height: 1.6;
      margin-bottom: 0.8rem;
    }
    .book-meta {
      display: flex;
      align-items: center;
      gap: 1rem;
      font-size: 0.85rem;
      color: #64748b;
    }
    .progress-bar {
      flex: 1;
      height: 6px;
      background: #2a2d3e;
      border-radius: 3px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      border-radius: 3px;
      transition: width 0.3s;
    }
    .badge {
      display: inline-block;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      font-size: 0.75rem;
      font-weight: 600;
    }
    .badge-done { background: #166534; color: #4ade80; }
    .badge-reading { background: #1e3a5f; color: #60a5fa; }
    .badge-queued { background: #1e1e2e; color: #64748b; }
    @media (min-width: 640px) {
      .book-grid { grid-template-columns: 1fr 1fr; }
      .catalog-hero h1 { font-size: 3rem; }
    }
  </style>
</head>
<body>
  <Header />
  <main>
    <div class="catalog-container">
      <div class="catalog-hero">
        <h1 data-i18n="textbookCatalogTitle">📖 教材精读</h1>
        <p data-i18n="textbookCatalogDesc">系统性学习预测相关教材 · 输出精读笔记与思维训练</p>
      </div>

      <div class="stats-bar">
        <div class="stat-item">
          <div class="stat-num">{books.length}</div>
          <div class="stat-label" data-i18n="statBooks">本教材</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">{books.reduce((s, b) => s + b.pages, 0).toLocaleString()}</div>
          <div class="stat-label" data-i18n="statPages">总页数</div>
        </div>
        <div class="stat-item">
          <div class="stat-num">{books.filter(b => b.status === 'done').length}</div>
          <div class="stat-label" data-i18n="statDone">已完成</div>
        </div>
      </div>

      <div class="book-grid">
        {books.map(book => {
          const pct = book.chapters > 0 ? Math.round(book.done / book.chapters * 100) : 0;
          const badgeClass = book.status === 'done' ? 'badge-done' : book.status === 'reading' ? 'badge-reading' : 'badge-queued';
          const badgeText = book.status === 'done' ? '✅ 已完成' : book.status === 'reading' ? '📖 学习中' : '⏳ 待学习';
          return (
            <a href={book.status !== 'queued' ? book.link : undefined}
               class={`book-card ${book.status === 'queued' ? 'queued' : ''}`}
               style={`--accent: ${book.color}`}>
              <div class="book-header">
                <span class="book-emoji">{book.emoji}</span>
                <div class="book-info">
                  <div class="book-title" data-i18n={`book_${book.id}_title`}>{book.titleZh}</div>
                  <div class="book-title-en">{book.title}</div>
                  <div class="book-author">{book.author} · {book.pages}p</div>
                </div>
              </div>
              <div class="book-desc" data-i18n={`book_${book.id}_desc`}>{book.descZh}</div>
              <div class="book-meta">
                <span class={`badge ${badgeClass}`}>{badgeText}</span>
                {book.chapters > 0 && (
                  <>
                    <div class="progress-bar">
                      <div class="progress-fill" style={`width: ${pct}%; background: ${book.color}`}></div>
                    </div>
                    <span>{book.done}/{book.chapters}</span>
                  </>
                )}
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </main>
  <Footer />
</body>
</html>
