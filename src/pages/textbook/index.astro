<!doctype html>
<html lang="zh">
<head>
  <BaseHead title={`📖 教材笔记 — ${SITE_TITLE}`} description="Yang & Kleissl (2024) 教材逐章逐节精读笔记" />
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.11/katex.min.css" crossorigin="anonymous" />
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.11/katex.min.js" crossorigin="anonymous"></script>
  <script defer src="https://cdnjs.cloudflare.com/ajax/libs/KaTeX/0.16.11/contrib/auto-render.min.js" crossorigin="anonymous"></script>
  <style>
    /* ── Layout: sidebar + content ── */
    .tb-wrap {
      display: flex;
      height: calc(100vh - 64px);
      overflow: hidden;
    }

    /* ── Sidebar (left outline) ── */
    .tb-sidebar {
      width: 280px;
      min-width: 280px;
      border-right: 1px solid var(--border);
      background: var(--bg-card);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .tb-sidebar-header {
      padding: 1rem;
      border-bottom: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--text-muted);
    }
    .tb-sidebar-header h2 {
      font-size: 0.9rem;
      color: var(--accent);
      margin: 0 0 0.3rem;
    }
    .tb-sidebar-header .progress {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      margin-top: 0.5rem;
    }
    .tb-sidebar-header .progress-track {
      flex: 1; height: 4px;
      background: var(--border); border-radius: 2px;
      overflow: hidden;
    }
    .tb-sidebar-header .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, var(--accent), #3dd68c);
      border-radius: 2px;
    }
    .tb-sidebar-header .progress-text {
      font-size: 0.7rem; white-space: nowrap;
    }
    .tb-tree {
      flex: 1;
      overflow-y: auto;
      padding: 0.5rem 0;
    }

    /* Tree items */
    .tree-ch {
      user-select: none;
    }
    .tree-ch-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      padding: 0.35rem 0.6rem 0.35rem 0.5rem;
      cursor: pointer;
      font-size: 0.82rem;
      color: var(--text);
      transition: background 0.15s;
    }
    .tree-ch-head:hover { background: rgba(245,158,11,0.08); }
    .tree-ch-head .arrow {
      font-size: 0.55rem;
      color: var(--text-muted);
      transition: transform 0.2s;
      width: 0.8rem;
      text-align: center;
      flex-shrink: 0;
    }
    .tree-ch.open > .tree-ch-head .arrow { transform: rotate(90deg); }
    .tree-ch-head .status-dot {
      width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .status-done { background: #3dd68c; }
    .status-wip { background: var(--accent); }
    .status-locked { background: var(--text-muted); opacity: 0.4; }
    .tree-ch-head .ch-label { font-weight: 600; color: var(--accent); margin-right: 0.3rem; flex-shrink: 0; }
    .tree-ch-head .ch-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .tree-ch-body { display: none; }
    .tree-ch.open > .tree-ch-body { display: block; }

    .tree-sec {
      user-select: none;
    }
    .tree-sec-head {
      display: flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.25rem 0.6rem 0.25rem 1.6rem;
      cursor: pointer;
      font-size: 0.78rem;
      color: var(--text);
      transition: background 0.15s;
    }
    .tree-sec-head:hover { background: rgba(245,158,11,0.06); }
    .tree-sec-head .arrow {
      font-size: 0.5rem; color: var(--text-muted);
      transition: transform 0.2s; width: 0.7rem; text-align: center; flex-shrink: 0;
    }
    .tree-sec.open > .tree-sec-head .arrow { transform: rotate(90deg); }
    .tree-sec-head .sec-id { color: #3dd68c; font-weight: 600; min-width: 1.8rem; flex-shrink: 0; }
    .tree-sec-head .sec-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

    .tree-sec-body { display: none; }
    .tree-sec.open > .tree-sec-body { display: block; }

    .tree-sub {
      display: flex;
      align-items: center;
      gap: 0.3rem;
      padding: 0.2rem 0.6rem 0.2rem 2.8rem;
      cursor: pointer;
      font-size: 0.75rem;
      color: var(--text-muted);
      transition: background 0.15s;
    }
    .tree-sub:hover { background: rgba(61,214,140,0.06); }
    .tree-sub.active { background: rgba(245,158,11,0.12); color: var(--accent); }
    .tree-sub .sub-id { color: #38bdf8; font-weight: 600; min-width: 2.2rem; flex-shrink: 0; }
    .tree-sub .sub-title { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .tree-sub .no-note { opacity: 0.4; font-style: italic; }

    /* Section-level clickable (no subsections) */
    .tree-sec-head.clickable.active { background: rgba(245,158,11,0.12); }
    .tree-sec-head.clickable.active .sec-title { color: var(--accent); }

    /* ── Content panel (right) ── */
    .tb-content {
      flex: 1;
      overflow-y: auto;
      padding: 2rem 3rem;
    }
    .tb-content .welcome {
      text-align: center;
      color: var(--text-muted);
      padding-top: 15vh;
    }
    .tb-content .welcome h2 { color: var(--accent); font-size: 1.4rem; margin-bottom: 0.5rem; }
    .tb-content .welcome p { font-size: 0.9rem; line-height: 1.7; }
    .tb-content .welcome .links { margin-top: 1.5rem; display: flex; gap: 1rem; justify-content: center; }
    .tb-content .welcome .links a {
      padding: 0.4rem 1rem; border-radius: 99px; border: 1px solid var(--border);
      background: var(--bg-card); color: var(--text-muted); text-decoration: none; font-size: 0.85rem;
      transition: all 0.2s;
    }
    .tb-content .welcome .links a:hover { border-color: var(--accent); color: var(--accent); }

    .note-panel { display: none; }
    .note-panel.active { display: block; }
    .note-panel .note-breadcrumb {
      font-size: 0.75rem;
      color: var(--text-muted);
      margin-bottom: 0.5rem;
    }
    .note-panel h2 {
      font-size: 1.3rem;
      color: var(--accent);
      margin: 0 0 1rem;
      padding-bottom: 0.8rem;
      border-bottom: 2px solid var(--accent);
    }
    .note-panel .note-body {
      font-size: 0.92rem;
      line-height: 1.9;
      color: var(--text);
      white-space: pre-wrap;
      max-width: 700px;
    }

    /* ── Mobile ── */
    @media (max-width: 768px) {
      .tb-sidebar { width: 240px; min-width: 240px; }
      .tb-content { padding: 1.5rem 1rem; }
    }
    @media (max-width: 600px) {
      .tb-wrap { flex-direction: column; height: auto; }
      .tb-sidebar {
        width: 100%; min-width: 100%;
        max-height: 50vh;
        border-right: none;
        border-bottom: 1px solid var(--border);
      }
      .tb-content { min-height: 50vh; }
    }
  </style>
</head>
<body>
  <Header />
  <div class="tb-wrap">
    <!-- ── Sidebar outline ── -->
    <aside class="tb-sidebar">
      <div class="tb-sidebar-header">
        <h2>📖 目录</h2>
        <div style="font-size:0.72rem; line-height:1.4;">
          Solar Irradiance and PV Power Forecasting<br/>
          Yang & Kleissl · CRC Press, 2024
        </div>
        <div class="progress">
          <div class="progress-track"><div class="progress-fill" style="width:33.3%"></div></div>
          <span class="progress-text">4/12</span>
        </div>
      </div>
      <nav class="tb-tree" id="tree">
        {chapters.map(ch => (
          <div class="tree-ch" data-ch={ch.id}>
            <div class="tree-ch-head">
              <span class="arrow">▶</span>
              <span class={`status-dot status-${ch.status}`}></span>
              <span class="ch-label">Ch{ch.num}</span>
              <span class="ch-title">{ch.title}</span>
            </div>
            <div class="tree-ch-body">
              {ch.sections.length === 0 ? (
                <div class="tree-sub"><span class="no-note">尚未学习</span></div>
              ) : ch.sections.map(sec => (
                sec.subsections ? (
                  <div class="tree-sec">
                    <div class={`tree-sec-head${sec.note ? ' clickable' : ''}`} data-note-id={sec.note ? `${ch.id}-${sec.id}` : undefined}>
                      <span class="arrow">▶</span>
                      <span class="sec-id">{sec.id}</span>
                      <span class="sec-title">{sec.title}</span>
                    </div>
                    <div class="tree-sec-body">
                      {sec.subsections.map((sub: any) => (
                        <div class={`tree-sub${sub.note ? '' : ' no-note-item'}`} data-note-id={sub.note ? `${ch.id}-${sub.id}` : undefined}>
                          <span class="sub-id">{sub.id}</span>
                          <span class={`sub-title${sub.note ? '' : ' no-note'}`}>{sub.title}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class={`tree-sub${sec.note ? '' : ' no-note-item'}`} data-note-id={sec.note ? `${ch.id}-${sec.id}` : undefined} style="padding-left:1.6rem;">
                    <span class="sub-id">{sec.id}</span>
                    <span class={`sub-title${sec.note ? '' : ' no-note'}`}>{sec.title}</span>
                  </div>
                )
              ))}
            </div>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ── Content panel ── -->
    <main class="tb-content" id="content">
      <div class="welcome" id="welcomePanel">
        <h2>📖 教材精读笔记</h2>
        <p>
          点击左侧目录展开章节<br/>
          选择小节查看详细笔记
        </p>
        <div class="links">
          <a href="/blog/">← 返回博客</a>
          <a href="/blog/textbook-thinking/">🧠 思维训练</a>
        </div>
      </div>
      {allNotes.map(n => (
        <div class="note-panel" id={`note-${n.id}`}>
          <div class="note-breadcrumb">Ch{n.chNum} › {n.secId}</div>
          <h2>{n.secId} {n.title}</h2>
          <div class="note-body" set:html={n.note.replace(/\\n/g, '<br/>')} />
        </div>
      ))}
    </main>
  </div>

  <script is:inline>
    // Toggle chapter
    document.querySelectorAll('.tree-ch-head').forEach(el => {
      el.addEventListener('click', () => el.parentElement.classList.toggle('open'));
    });
    // Toggle section
    document.querySelectorAll('.tree-sec-head').forEach(el => {
      el.addEventListener('click', (e) => {
        const sec = el.parentElement;
        // If has note and is clickable, show note; otherwise just toggle
        if (el.dataset.noteId) {
          showNote(el.dataset.noteId, el);
        }
        sec.classList.toggle('open');
      });
    });
    // Click subsection → show note
    document.querySelectorAll('.tree-sub[data-note-id]').forEach(el => {
      el.addEventListener('click', () => showNote(el.dataset.noteId, el));
    });

    function showNote(noteId, clickedEl) {
      // Hide all notes
      document.querySelectorAll('.note-panel').forEach(p => p.classList.remove('active'));
      document.getElementById('welcomePanel').style.display = 'none';
      // Show target
      const target = document.getElementById('note-' + noteId);
      if (target) target.classList.add('active');
      // Update active state
      document.querySelectorAll('.tree-sub.active, .tree-sec-head.active').forEach(el => el.classList.remove('active'));
      clickedEl.classList.add('active');
      // Render math in the newly shown note
      tryRenderMath(target);
    }

    function tryRenderMath(el) {
      if (!el) return;
      if (el.dataset.mathRendered) return;
      if (window.renderMathInElement) {
        renderMathInElement(el, {
          delimiters: [
            {left: '$$', right: '$$', display: true},
            {left: '$', right: '$', display: false},
          ],
          throwOnError: false,
        });
        el.dataset.mathRendered = '1';
      } else {
        // KaTeX not loaded yet, retry in 500ms
        setTimeout(() => tryRenderMath(el), 500);
      }
    }
  </script>
</body>
</html>
