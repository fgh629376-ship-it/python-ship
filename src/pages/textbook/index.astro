// Helper: flatten all notes for content panel
function getAllNotes(chapters: any[]) {
  const notes: any[] = [];
  for (const ch of chapters) {
    for (const sec of ch.sections) {
      if (sec.note) notes.push({ id: `${ch.id}-${sec.id}`, chNum: ch.num, secId: sec.id, title: sec.title, note: sec.note });
      if (sec.subsections) {
        for (const sub of sec.subsections) {
          if (sub.note) notes.push({ id: `${ch.id}-${sub.id}`, chNum: ch.num, secId: sub.id, title: sub.title, note: sub.note });
        }
      }
    }
  }
  return notes;
}
const allNotes = getAllNotes(chapters);
