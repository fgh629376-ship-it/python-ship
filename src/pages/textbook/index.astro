          Yang & Kleissl · CRC Press, 2024
        </div>
        <div class="progress">
          <div class="progress-track"><div class="progress-fill" style="width:33.3%"></div></div>
          <span class="progress-text">4/12</span>
        </div>
      </div>
      <nav class="tb-tree" id="tree">
        {chapters.map(ch => (
          <div class="tree-ch" data-ch={ch.id}>
            <div class="tree-ch-head">
              <span class="arrow">▶</span>
              <span class={`status-dot status-${ch.status}`}></span>
              <span class="ch-label">Ch{ch.num}</span>
              <span class="ch-title">{ch.title}</span>
            </div>
            <div class="tree-ch-body">
              {ch.sections.length === 0 ? (
                <div class="tree-sub"><span class="no-note">尚未学习</span></div>
              ) : ch.sections.map(sec => (
                sec.subsections ? (
                  <div class="tree-sec">
                    <div class={`tree-sec-head${sec.note ? ' clickable' : ''}`} data-note-id={sec.note ? `${ch.id}-${sec.id}` : undefined}>
                      <span class="arrow">▶</span>
                      <span class="sec-id">{sec.id}</span>
                      <span class="sec-title">{sec.title}</span>
                    </div>
                    <div class="tree-sec-body">
                      {sec.subsections.map((sub: any) => (
                        <div class={`tree-sub${sub.note ? '' : ' no-note-item'}`} data-note-id={sub.note ? `${ch.id}-${sub.id}` : undefined}>
                          <span class="sub-id">{sub.id}</span>
                          <span class={`sub-title${sub.note ? '' : ' no-note'}`}>{sub.title}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class={`tree-sub${sec.note ? '' : ' no-note-item'}`} data-note-id={sec.note ? `${ch.id}-${sec.id}` : undefined} style="padding-left:1.6rem;">
                    <span class="sub-id">{sec.id}</span>
                    <span class={`sub-title${sec.note ? '' : ' no-note'}`}>{sec.title}</span>
                  </div>
                )
              ))}
            </div>
          </div>
        ))}
      </nav>
    </aside>

    <!-- ── Content panel ── -->
    <main class="tb-content" id="content">
      <div class="welcome" id="welcomePanel">
        <h2>📖 教材精读笔记</h2>
        <p>
          点击左侧目录展开章节<br/>
          选择小节查看详细笔记
        </p>
        <div class="links">
          <a href="/blog/">← 返回博客</a>
          <a href="/blog/textbook-thinking/">🧠 思维训练</a>
        </div>
      </div>
      {allNotes.map(n => (
        <div class="note-panel" id={`note-${n.id}`}>
          <div class="note-breadcrumb">Ch{n.chNum} › {n.secId}</div>
          <h2>{n.secId} {n.title}</h2>
          <div class="note-body">{n.note}</div>
        </div>
      ))}
    </main>
  </div>

  <script is:inline>
    // Toggle chapter
    document.querySelectorAll('.tree-ch-head').forEach(el => {
      el.addEventListener('click', () => el.parentElement.classList.toggle('open'));
    });
    // Toggle section
    document.querySelectorAll('.tree-sec-head').forEach(el => {
      el.addEventListener('click', (e) => {
        const sec = el.parentElement;
        // If has note and is clickable, show note; otherwise just toggle
        if (el.dataset.noteId) {
          showNote(el.dataset.noteId, el);
        }
        sec.classList.toggle('open');
      });
    });
    // Click subsection → show note
    document.querySelectorAll('.tree-sub[data-note-id]').forEach(el => {
      el.addEventListener('click', () => showNote(el.dataset.noteId, el));
    });

    function showNote(noteId, clickedEl) {
      // Hide all notes
      document.querySelectorAll('.note-panel').forEach(p => p.classList.remove('active'));
      document.getElementById('welcomePanel').style.display = 'none';
      // Show target
      const target = document.getElementById('note-' + noteId);
      if (target) target.classList.add('active');
      // Update active state
      document.querySelectorAll('.tree-sub.active, .tree-sec-head.active').forEach(el => el.classList.remove('active'));
      clickedEl.classList.add('active');
    }
  </script>
</body>
</html>
