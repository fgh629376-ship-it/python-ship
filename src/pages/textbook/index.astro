import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const chapters = [
  {
    id: 'ch1', num: 1, status: '✅',
    title: 'Why We Do Solar Forecasting',
    titleZh: '为什么做光伏预测',
    pages: 'p1-25',
    sections: [
      { id: '1.1', title: '光伏预测的五个方面', subsections: [
        { id: '1.1.1', title: '基础方法 (Base Methods)', note: '五大基础方法按预测范围排列：①天空相机(ASI)：地面鱼眼镜头拍摄云图，光流法追踪云运动，有效范围~30分钟，优点是空间分辨率高，缺点是视野有限且假设云场"冻结"。②卫星(Satellite)：气象卫星红外/可见光通道，云运动矢量(CMV)平流预测，有效范围~4小时，覆盖范围大但时空分辨率受限。③NWP(数值天气预报)：求解大气运动的7个原始方程（3动量+热力学+水汽+质量+状态方程），有效范围1-15天，是日前预测的唯一可靠来源，但计算昂贵且依赖初始条件质量。④统计方法：ARIMA、ETS、VAR等时序模型，灵活且计算快，但无法捕获云的空间动态。⑤机器学习：从数据中学习非线性映射，可融合多源数据，但需要大量训练数据且缺乏物理可解释性。关键认识：不同方法适用于不同预测范围，不存在"一个方法通吃"的情况。' },
        { id: '1.1.2', title: '后处理 (Post-processing)', note: '后处理是连接基础预测和最终产品的桥梁，教材定义了10类技术，按输入/输出的确定性(D)和概率性(P)分为四象限：【D2D】确定性→确定性：回归(线性/非线性修正NWP偏差)、滤波(卡尔曼滤波等自适应校正)、降尺度(从粗网格到细网格)。【D2P】确定性→概率性：模拟集成(analog ensemble,从历史中找相似情况)、分布穿衣(dressing,给确定性预测加不确定性包络)、概率回归(分位数回归/NGBoost)。【P2D】概率性→确定性：汇总分布(取均值/中位数)、组合确定性预测(多模型加权平均)。【P2P】概率性→概率性：校准集成(BMA/EMOS修正集成预测偏差)、组合概率预测(多个概率预测的最优融合)。共10类，覆盖了从原始预测到最终产品的所有可能转换路径。后处理是提升预测质量最直接有效的手段。' },
        { id: '1.1.3', title: '验证 (Verification)', note: 'Murphy (1993) 提出预测质量三维度框架，至今仍是预测验证的理论基石：①一致性(Consistency)：预测者是否相信自己的预测？即发布的预测是否反映了预测者的真实最佳判断。如果预测者知道明天大概率下雨但报了晴天，就违反了一致性。②质量(Quality)：预测与观测的统计对应关系有多好？包括准确度(RMSE/MAE)、可靠度(校准)、分辨度(区分不同情况的能力)。③价值(Value)：预测对用户决策的经济或社会帮助有多大？关键洞察：三者可以冲突——高质量的概率预测如果用户不会解读，就没有价值；一致但质量差的预测至少是诚实的。预测精度每提升1%，大电网可节省数百万美元——这就是价值维度的具体体现。' },
        { id: '1.1.4', title: '辐照度→功率转换', note: '从辐照度预测到功率预测不是简单的"辐照度×效率"。需要完整的Model Chain（物理模型链），每一步都有专门的物理模型：①太阳位置算法(SPA)：计算天顶角Z、方位角，精度±0.0003°。②分离模型：从GHI分离出直射BNI和散射DHI，常用Erbs/BRL模型，输入是混浊指数kt=GHI/E₀。③转置模型：将水平面辐照度转为面板平面辐照度(POA/GTI)，GTI=Bn·cos(θ)+Rd·Dh+ρg·Rr·Gh，Perez模型最准。④温度模型：T_cell=T_amb+(NOCT-20)/800×GTI，电池温度直接影响效率。⑤PV电气模型：P=P_dc_ref×(GTI/1000)×[1+γ(T_cell-25)]，γ是温度系数(典型-0.4%/°C)。还有反射损失、污垢损失、线缆损失、逆变器效率等。关键：最佳个体模型的组合不一定是最佳Model Chain，因为误差会在各步之间传播和累积。' },
        { id: '1.1.5', title: '电网集成 (Grid Integration)', note: '预测最终服务于电网运营，不同运营场景对预测的要求截然不同：①日前市场(DAM, Day-Ahead Market)：需要>36小时预测，电力交易的主要市场，前一天上午提交次日24小时的功率预测和竞价。②实时市场(RTM, Real-Time Market)：需要>4小时预测，用于日内调度和偏差平衡，每15分钟或每小时更新。③频率调节(Frequency Regulation)：需要分钟级甚至秒级预测，维持电网50/60Hz频率稳定，对响应速度要求极高。④备用容量调度(Reserve Scheduling)：基于概率预测评估需要多少备用发电机组，概率预测在此场景价值最大。⑤长期规划：年度级别，用于输电线路建设、电厂规划等。光伏预测精度直接影响：电力交易收益（预测偏差=罚款）、备用容量成本（过度保守=浪费）、电网稳定性（预测失败=可能停电）。这就是为什么预测研究必须紧密对接电网运营标准。' },
      ]},
      { id: '1.2', title: '本书大纲', subsections: [
        { id: '1.2.1', title: '理解先于行动', note: '教材的核心哲学：不要一上来就跑模型。正确的学习路径是：先理解预测的物理基础（大气辐射传输、云动力学）→ 掌握统计理论（概率分布、集成方法、验证框架）→ 熟悉实践标准（电网运营要求、数据质量控制）→ 然后才动手建模。教材前四章(Ch1-4)专注于"理解"：为什么预测(Ch1)、如何批判性思考(Ch2)、确定性vs概率性(Ch3)、光伏vs其他能源预测(Ch4)。这种"理论先行"的安排在光伏预测领域是罕见的——大多数教程直接跳到代码和模型，导致很多从业者知道"怎么做"但不知道"为什么"。' },
        { id: '1.2.2', title: '电网集成与可调度太阳能', note: '教材的终极目标不只是提高预测精度，而是实现可调度太阳能(Dispatchable Solar Power)。传统电厂（火电/核电）可以按需调度——电网需要多少电就发多少电。光伏天然不可调度（取决于天气），但通过三要素组合可以接近可调度：①高质量预测（告诉电网未来会发多少电）②储能系统（在光照充足时储存，不足时释放）③智能调度算法（基于预测和储能状态优化出力曲线）。这三者的协同就是"稳固功率交付(Firm Power Delivery)"的概念，详见教材Ch12。这个目标解释了为什么教材同时覆盖预测方法和电网运营——它们不是两个独立话题，而是一个完整系统的两面。' },
      ]},
    ],
  },
  {
    id: 'ch2', num: 2, status: '✅',
    title: 'Philosophical Thinking Tools',
    titleZh: '哲学思维工具',
    pages: 'p26-49',
    sections: [
      { id: '2.1', title: '与匿名者争论', note: '学术审稿是双盲匿名的——你看不到审稿人是谁，审稿人也不知道你是谁（理论上）。这创造了一个独特的争论环境：你无法利用权威、关系或情感来说服对方，只能依靠逻辑和证据。教材强调：回复审稿意见时，每一条反驳都必须有数据支撑或逻辑推导，模糊的"我们认为"式回应会被直接忽略。反过来，作为审稿人，也应该基于科学标准而非个人偏好来评判。这个规则同样适用于日常的技术讨论——用数据说话，不用立场说话。' },
      { id: '2.2', title: '拉波波特规则 (Rapoport\'s Rule)', note: '批评他人工作前的四步规则（来自博弈论学家Anatol Rapoport）：①先重述对方的观点，重述到对方会说"是的，这正是我的意思"的程度。②列出你同意对方的部分（通常比你以为的多）。③明确说明你从对方那里学到了什么。④然后才开始你的批评。核心思想：大多数学术争论的根源不是观点分歧，而是双方根本没有理解对方在说什么。先理解再批评，不仅是礼貌，更是避免无效争论的最有效手段。在光伏预测领域，很多"方法A比方法B好"的争论，其实是因为双方使用了不同的数据集、不同的评估指标、或不同的预测范围——如果先确认这些前提，争论往往不攻自破。' },
      { id: '2.3', title: '还原论：什么是"好"', note: 'Murphy (1993) 将预测的"好"还原为三个独立维度，这是预测验证的理论基石：①一致性(Consistency)：预测者是否真诚地发布了自己的最佳判断？如果预测模型输出概率为70%会下雨，但预测者因为害怕惩罚改成50%发布，就违反了一致性。②质量(Quality)：预测与实际观测的统计对应关系。包括准确度(bias有多大)、可靠度(说70%的事件是否真的70%发生)、分辨度(能否区分不同情况)。③价值(Value)：预测对用户决策带来的经济或社会收益。关键洞察：三者可以独立变化！一个高质量的概率预测，如果调度人员不懂概率、只看点预测，那它的价值就和普通点预测一样。一个完全诚实但技术差的预测，一致性高但质量低。理解这三个维度的独立性，是避免"我的RMSE最低所以我最好"这种简单化思维的关键。' },
      { id: '2.4', title: '"我掌控未来"', note: '预测科学的三大哲学基础（受Karl Popper影响）：①可预测性(Predictability)：不是一切都能预测。天气的可预测性取决于空间尺度（局部vs区域）、时间范围（小时vs天）、天气状况（晴天几乎完美可预测，阴晴交替最难）。认识到可预测性的极限，就不会盲目追求更复杂的模型——有些误差是不可约的。②好的预测(Good Forecasts)：Murphy三维度（见2.3），好的预测不等于完美预测，而是在可预测性极限内做到最好。③可证伪性(Falsifiability)：Popper的核心主张——不能被推翻的结论不是科学。如果一个预测方法不能被复现和验证，它就不具备科学性。这也是为什么教材反复强调可重现性——不提供代码和数据的论文，本质上是不可证伪的。' },
      { id: '2.5', title: '奥卡姆剃刀 (Occam\'s Razor)', note: '"如无必要，勿增实体"——14世纪方济各会修士William of Ockham的原则。在光伏预测中的具体应用：如果线性回归能达到RMSE=50W/m²，而20层深度网络达到49W/m²，那1W/m²的提升是否值得10倍的模型复杂度和训练时间？通常不值得。Markovics & Mayer (2022) 在68个ML模型的大比较中证实：XGBoost/LightGBM（相对简单的集成树模型）在日前预测中整体最优，深度学习并未显著优于传统ML。教材引申：模型复杂度的增加必须用统计显著的精度提升来证明（Diebold-Mariano检验）。简单模型还有可解释性优势——你能说清楚XGBoost每个特征的贡献，但很难解释LSTM的隐层在学什么。' },
      { id: '2.6', title: '奥卡姆扫帚 (Occam\'s Broom)', note: '比剃刀更隐蔽也更危险的问题：把不利的事实"扫到地毯下面"，假装它们不存在。在光伏预测论文中的常见表现：①只报告对自己有利的误差指标（比如只报R²不报RMSE，因为光伏出力有强日周期导致R²天然很高）。②选择性展示"好的"时间段（只展示晴天结果，避开多云天气的惨淡表现）。③不报告与持续性模型(persistence)的对比——如果你的"先进"模型打不过最简单的持续性，说明有根本问题。④隐藏模型在特定天气条件下的灾难性失败（如突变天气下误差暴增10倍）。⑤不报告负面实验（尝试了但失败的方法）。教材忠告：诚实报告所有结果，包括不好看的。负面结果对科学的价值可能比正面结果更大——它告诉后人哪条路走不通。' },
      { id: '2.7', title: '"新颖"算子 (The "Novel" Operator)', note: '学术论文中最被滥用的词就是"novel"（新颖）。教材批判的典型模式："We propose a novel hybrid CNN-LSTM-Attention-Transformer model for solar forecasting"——实际上只是把现有的深度学习模块像积木一样拼在一起，每个模块都不是新的，拼接方式也谈不上创新。教材认为真正的新颖有三个层次：①新问题（发现了一个前人没注意的预测场景或需求）②新理解（对已知现象提出了新的物理或统计解释）③新发现（用实验证据推翻了领域内的普遍信念）。仅仅是"新排列组合"不构成真正的新颖。对我们的启示：做光伏预测不要追求模型的花哨，而是追求对问题本身的深入理解。理解清楚了，用最简单的方法也能做出好预测。' },
      { id: '2.8', title: '烟雾弹 (The Smoke Grenade)', note: '用复杂的数学公式和冗长的流程图来掩盖内容的空洞——教材称之为"烟雾弹"。典型特征：①用三页推导一个标准线性回归的公式，让它看起来像是全新的数学贡献。②画极其复杂的流程图（20+个方框和箭头），但核心步骤其实只有三步。③大量使用自造缩写和术语（如"MSCNN-BiLSTM-SA-DWT"），让读者无法快速理解在做什么。④公式中使用了大量符号但不给直觉解释，纯粹靠数学形式吓唬人。教材的判断标准：如果一个方法不能用简单的话向一个聪明的外行解释清楚，要么这个方法确实非常复杂（如辐射传输理论），要么作者自己也没真正搞懂。爱因斯坦说"Everything should be made as simple as possible, but not simpler"——这也是Ch5的开篇引言。' },
      { id: '2.9', title: '用外行作诱饵', note: '这是教材提出的反制烟雾弹的策略。核心思想：写论文时假设读者是一个聪明但不是本领域的外行（比如一个电力系统工程师来读你的气象预测论文）。如果这个外行能理解你方法的核心思想和逻辑，说明你写得够清楚。如果他一头雾水，说明你要么写得太晦涩，要么方法本身没有清晰的逻辑。可重现性(reproducibility)是最好的去烟雾弹手段——当你提供了完整的代码和数据，任何人都可以验证你的方法是否真如你所说的那么好，再多的烟雾弹也会被真实数据戳穿。教材作者建议：提供代码（ostensive reproducibility，展示性可重现）远优于只提供文字描述（verbal reproducibility，口头可重现）。' },
      { id: '2.10', title: '砖块与阶梯', note: '科学进步的两种方式：①砖块(Bricks)：一块一块往上垒，每块砖都在前人的基础上增加一点点新东西。大多数论文都是砖块——用新数据验证已有方法、用已有方法解决新场景、对已有方法做小改进。这没有任何问题，科学大厦就是砖块垒起来的。②阶梯(Ladders)：直接跳到更高的层次，范式转换。在光伏预测中，晴空模型的引入就是一个阶梯——它从根本上改变了"如何去除太阳辐照度中的季节性"这个问题的解法。Gneiting (2007)的校准+锐度范式也是一个阶梯——它重新定义了什么是"好的概率预测"。教材的告诫：大多数研究者一生都在搬砖，这完全正常也很有价值。但要有意识地辨别砖块和阶梯，不要把搬砖误认为爬梯（即不要把增量改进包装成革命性创新），也不要因为在搬砖就看不到阶梯的存在。' },
    ],
  },
  {
    id: 'ch3', num: 3, status: '✅',
    title: 'Deterministic and Probabilistic Forecasts',
    titleZh: '确定性与概率性预测',
    pages: 'p50-82',
    sections: [
      { id: '3.1', title: '物理世界的确定性本质', note: '核心推理链：所有混沌系统都是确定性的→天气是混沌系统→天气是确定性的。拉普拉斯妖思想实验。但确定性≠可预测——初始条件不完美+物理定律不完美导致误差指数增长。' },
      { id: '3.2', title: '不确定性与分布预测', subsections: [
        { id: '3.2.1', title: '概率分布基础', note: 'CDF: F(x)=P(X≤x)，值域[0,1]。PDF: f(x)=F\'(x)，值可>1（常见误解）。辐照度有物理上下界，Gaussian分布(±∞)不适合。' },
        { id: '3.2.2', title: '预测分布', note: 'Nature选真实分布Gᵢ，预测者发布Fᵢ。分位数：τ分位数=F⁻¹(τ)。⚠️当X范围也是[0,1]时（如κ），极易混淆τ和分位数值。' },
        { id: '3.2.3', title: '理想预测分布 (Gneiting 2007)', note: '概率预测验证基石。核心范式：在校准(calibration)约束下最大化锐度(sharpness)。校准=说80%就真80%。锐度=区间越窄越好。两者有张力。' },
        { id: '3.2.4', title: '预测分布类型', note: '四种：参数型(高斯,需截断) / 半参数型(混合高斯,捕获双峰) / 非参数型(KDE) / 经验型(ECDF)。辐照度天然双峰，混合高斯最适合。' },
        { id: '3.2.5', title: '分布预测的其他表示', note: '分位数预测(报告q₀.₁,q₀.₅,q₀.₉) / 区间预测([α/2,1-α/2]分位数) / 集成预测(多个确定性预测的集合)。' },
      ]},
      { id: '3.3', title: '集成预测', subsections: [
        { id: '3.3.1', title: '气象集成类型', note: '三种：动力集成(扰动初始条件,ECMWF EPS 50+1成员)→数据不确定性 / 穷人集成(不同模型)→过程不确定性 / 随机参数化(不同物理方案)→参数不确定性。' },
        { id: '3.3.2', title: '统计集成预测', note: '数据集成(不同历史长度/Bootstrap/多数据源) / 过程集成(ARIMA族/ETS族/STL/X11/傅里叶/小波分解) / 参数集成(调整ARIMA的p,d,q)。TBATS=三角+Box-Cox+ARMA+趋势+季节。' },
        { id: '3.3.3', title: '集成学习', note: 'Bagging：Bootstrap+平均，降方差，可并行，保证MSE≤平均但不保证≤最好。Boosting：顺序构建，聚焦错误样本(权重×exp(α))，降偏差，AdaBoost→XGBoost。Stacking：基学习器+超级学习器(通过CV训练)，常用正则化回归。' },
      ]},
      { id: '3.4', title: '深思', note: '本节提出两个深层问题：①统计集成vs集成学习的核心区别是什么？答：是否能访问组件预测。统计集成（穷人集成）可以看到每个组件模型的输出，因此可以做加权组合、校准等精细操作。集成学习工具箱（如sklearn的RandomForest）通常只输出最终组合结果，内部树的预测对用户不可见。②概率预测→确定性预测的转换看似简单，实则暗藏陷阱。如果你用预测分布的均值作为点预测，那评估时应该用MSE（因为MSE在均值处最小化）。如果用中位数作为点预测，应该用MAE（MAE在中位数处最小化）。如果用众数，应该用0-1损失。大多数太阳预测论文从来没问过"我用的点预测是均值还是中位数"——他们只是用sklearn.predict()然后报告RMSE，完全没意识到这个选择会影响评估结果。这个问题看似学术，实际上在偏态分布（如辐照度）下差异显著。' },
    ],
  },
  {
    id: 'ch4', num: 4, status: '✅',
    title: 'Solar Forecasting: The New Member of the Band',
    titleZh: '光伏预测：乐队新成员',
    pages: 'p83-128',
    sections: [
      { id: '4.1', title: '能源预测各领域成熟度', note: 'GEFCom2014首次大规模跨域对比(581人,61国)。成熟度四象限：STLF最成熟/风力概率性最成熟/电价确定性较成熟/光伏两方面都最不成熟(2010s才起步，社区闭塞"living in a bubble")。' },
      { id: '4.2', title: '负荷预测：微小差异很重要', subsections: [
        { id: '4.2.1', title: '鸟瞰负荷预测', note: '本质是回归问题。最佳技巧(Hong&Fan 2016)：两阶段法——非黑盒多变量捕主特征+黑盒单变量处理残差。主要特征：星期几/日历/温度(最重要)/层次结构。' },
        { id: '4.2.2', title: '评估负荷预测质量', note: 'MAPE最常用，典型误差仅3%。1%MAPE≈几十万美元/GW peak。采样不确定性：模型差异可能只有0.002%，需Diebold-Mariano检验。' },
        { id: '4.2.3', title: '近期创新', note: '纯应用新ML已不够新颖——必须回答why and how。大数据/IoT细粒度监测。峰值负荷预测。网络安全攻击下的鲁棒预测。' },
      ]},
      { id: '4.3', title: '风力预测：一切关于天气', subsections: [
        { id: '4.3.1', title: 'NWP与风速预测', note: '<3h统计/ML够用，>3h必须NWP。风速是预报变量(动量方程)。验证注意：局部暴露/尺度不匹配/山地困难——全部适用于光伏！' },
        { id: '4.3.2', title: '风功率曲线建模', note: '非单射映射(同一风速多个功率)。P=½CₚρπR²W³。四区域：启动前/立方增长/额定/停机。S型曲线拟合or回归。' },
        { id: '4.3.3', title: '统计与机器学习', note: '三用途：NWP后处理/功率曲线建模/直接生成预测。Pinson四大挑战：信息利用/运营整合/大维度验证/质量-价值对应。' },
      ]},
      { id: '4.4', title: '电价预测：因果关系', subsections: [
        { id: '4.4.1', title: '市场与预测范围', note: '术语差异：欧洲spot=日前价格，澳洲/北美spot=实时价格。时间线：年合同→季月周→日前拍卖→日内/实时→平衡市场。>90%论文聚焦日前。' },
        { id: '4.4.2', title: '短期价格预测模型', note: '本质是回归Y=x\'β+ε。Lasso/Elastic Net自动变量选择(L1惩罚缩到零)。可扩展到分位数回归(pinball loss)。ANN/LSTM建模非线性和时序动态。VAR同时估计24小时。' },
        { id: '4.4.3', title: '建模技巧', note: '三大技巧：①方差稳定化VST(电价可为负→用asinh) ②季节分解(趋势+随机分别建模再组合) ③校准窗口平均(多窗口组合>单一最优窗口)。全部可迁移到光伏。' },
      ]},
      { id: '4.5', title: '太阳辐照度的突出特征', subsections: [
        { id: '4.5.1', title: '晴空期望', note: '光伏预测最大武器！REST2模型：Bnc=E₀ₙ×T_R×T_g×T_o×T_n×T_w×T_a（六种大气衰减相乘）。GEFCom2014唯一用晴空模型的团队=冠军。75+个GHI模型，REST2v9.1质量最高。' },
        { id: '4.5.2', title: '晴空指数分布', note: '乘法分解(κ)>加法分解(κ\')。κ分布通常双峰(晴天≈1.0+阴天≈0.3-0.5)。⚠️常见错误：假设GHI服从Beta分布(GHI可超晴空值)/直接对GHI算相关性(夸大季节虚假相关)。' },
        { id: '4.5.3', title: '物理极限', note: '下界≈0。上界≈1.5×晴空值(云增强+反照率增强)。1秒~1900W/m²，1分钟~1600W/m²，>5分钟趋平均。Gaussian不适合辐照度(有物理界)。' },
        { id: '4.5.4', title: '时空依赖', note: '去季节后相关性完全来自移动云。相机<30min/卫星<4h/NWP>4h。电网需>4h(RTM)+>36h(DAM)→NWP是唯一可靠来源。传感器网络>数公里后衰减，不可扩展。' },
        { id: '4.5.5', title: '光伏功率曲线 (Model Chain)', note: '四步：分离(kt→Bn,Dh)→转置(GTI)→温度(T_cell)→功率(P)。⚠️最优个体模型组合≠最优Model Chain，误差传播机制复杂，必须整体优化。' },
      ]},
      { id: '4.6', title: '共享研究前沿', subsections: [
        { id: '4.6.1', title: '先进物理预测', note: '能源预测者≠天气预测者，知识不匹配。大多数只用NWP现成产品。机会：用全球NWP作边界条件运行区域高分辨率(WRF-Solar)。' },
        { id: '4.6.2', title: '机器学习', note: 'ML在能源预测已30+年。深度学习需大量数据(几年单站不够)。当前文献重形式轻本质。物理特征必须融入ML。"没有决定性证据结束DL辩论"。' },
        { id: '4.6.3', title: '集成与概率预测', note: '概率预测是最重要的思维转变。能源预测者是天气预测用户，主要工作是后处理。工业界接受度低——保守运营，与运营脱节的研究没有内在价值。' },
        { id: '4.6.4', title: '层次预测', note: '个体→区域→全网必须聚合一致。最优调和(Hyndman 2011)利用所有层级信息。电网法规要求系统所有者提交预测(合规+减罚款)。可统一负荷+风力+光伏为净负荷预测。' },
      ]},
      { id: '4.7', title: '常见问题与建议', subsections: [
        { id: '4.7.1', title: '常见问题', note: '①数据集有限(专有/上下文特定→不可泛化) ②验证不足(错误指标如对零值用MAPE/弱基准/验证集太小，至少需一年小时级) ③术语不一致(reinvent jargon)。' },
        { id: '4.7.2', title: '建议', note: '①文献综述注重逻辑流 ②术语精确(不说短期,说horizon=24h) ③提供代码+数据(ostensive>verbal) ④选有专家的期刊 ⑤坚持不懈——理解∝时间。' },
      ]},
      { id: '4.8', title: '章节总结', note: '终极结论：晴空模型是最重要的考虑/纯数据驱动单站方法seriously handicapped/最佳路径=辐照度→后处理→Model Chain→功率/需要特殊数据的方法不值得推广。' },
    ],
  },
  {
    id: 'ch5', num: 5, status: '🔜',
    title: 'A Guide to Good Housekeeping',
    titleZh: '良好工作习惯指南',
    pages: 'p129-168',
