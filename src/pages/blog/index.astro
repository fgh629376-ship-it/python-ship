---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const CATEGORIES = [
	{ id: 'all',    label: '全部',       emoji: '📚' },
	{ id: 'python', label: 'Python 语法', emoji: '🐍' },
	{ id: 'solar',  label: '光伏能源',    emoji: '☀️' },
];
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead title={`博客 — ${SITE_TITLE}`} description="Python 技术干货 + 光伏能源学习笔记" />
		<style>
			/* Category tabs */
			.cat-tabs {
				display: flex;
				gap: 0.6rem;
				margin-bottom: 2rem;
				flex-wrap: wrap;
			}
			.cat-tab {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.45rem 1.1rem;
				border-radius: 99px;
				border: 1px solid var(--border);
				background: var(--bg-card);
				color: var(--text-muted);
				font-size: 0.88rem;
				cursor: pointer;
				transition: all 0.18s;
				font-family: inherit;
			}
			.cat-tab:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.cat-tab.active {
				background: var(--accent);
				border-color: var(--accent);
				color: #1a1b26;
				font-weight: 700;
			}

			/* Category badge on card */
			.cat-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.1rem 0.55rem;
				border-radius: 4px;
				font-size: 0.75rem;
				font-weight: 600;
				margin-bottom: 0.5rem;
			}
			.cat-badge.python {
				background: rgba(61, 214, 140, 0.12);
				color: var(--accent);
				border: 1px solid rgba(61, 214, 140, 0.3);
			}
			.cat-badge.solar {
				background: rgba(255, 196, 0, 0.12);
				color: #ffc400;
				border: 1px solid rgba(255, 196, 0, 0.3);
			}

			/* Post list */
			.post-list { list-style: none; margin: 0; padding: 0; }
			.post-list li { margin-bottom: 1.2rem; }
			.post-list li[hidden] { display: none; }

			.post-card {
				display: block;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				padding: 1.4rem 1.6rem;
				text-decoration: none;
				transition: border-color 0.18s, transform 0.18s;
			}
			.post-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.post-card h2 {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: var(--text);
				border: none;
				padding: 0;
			}
			.post-card:hover h2 { color: var(--accent); }
			.post-card .meta {
				color: var(--text-muted);
				font-size: 0.82rem;
				margin-bottom: 0.5rem;
			}
			.post-card .excerpt {
				color: var(--text-muted);
				font-size: 0.9rem;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* Page header */
			.page-header {
				margin-bottom: 1.8rem;
				padding-bottom: 1.2rem;
				border-bottom: 1px solid var(--border);
			}
			.page-header h1 { margin: 0 0 0.3rem; font-size: 1.6rem; }
			.page-header p { color: var(--text-muted); font-size: 0.9rem; margin: 0; }

			.no-posts {
				text-align: center;
				color: var(--text-muted);
				padding: 3rem 0;
				display: none;
			}
			.no-posts.visible { display: block; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>📖 博客</h1>
				<p>Python 技术干货 · 光伏能源笔记 · 持续更新中</p>
			</div>

			<!-- Category tabs -->
			<div class="cat-tabs" id="catTabs">
				{CATEGORIES.map((c) => (
					<button
						class={`cat-tab${c.id === 'all' ? ' active' : ''}`}
						data-cat={c.id}
					>
						<span>{c.emoji}</span>{c.label}
					</button>
				))}
			</div>

			<!-- Post list -->
			<ul class="post-list" id="postList">
				{posts.map((post) => (
					<li data-category={post.data.category}>
						<a class="post-card" href={`/blog/${post.id}/`}>
							<span class={`cat-badge ${post.data.category}`}>
								{post.data.category === 'python' ? '🐍 Python' : '☀️ 光伏'}
							</span>
							<h2>{post.data.title}</h2>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="excerpt">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>

			<p class="no-posts" id="noPosts">该分类暂无文章</p>
		</main>
		<Footer />

		<script>
			const tabs = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
			const items = document.querySelectorAll<HTMLLIElement>('#postList li');
			const noPostsEl = document.getElementById('noPosts')!;

			function filter(cat: string) {
				let visible = 0;
				items.forEach((li) => {
					const match = cat === 'all' || li.dataset.category === cat;
					li.hidden = !match;
					if (match) visible++;
				});
				noPostsEl.classList.toggle('visible', visible === 0);
			}

			tabs.forEach((btn) => {
				btn.addEventListener('click', () => {
					tabs.forEach((b) => b.classList.remove('active'));
					btn.classList.add('active');
					filter(btn.dataset.cat!);
				});
			});
		</script>
	</body>
</html>
