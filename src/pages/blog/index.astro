---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const CATEGORIES = [
	{ id: 'all',       label: '全部',         emoji: '📚', i18n: 'catAll' },
	{ id: 'python',    label: 'Python 语法',  emoji: '🐍', i18n: 'catTabPython' },
	{ id: 'solar',     label: '光伏能源',     emoji: '☀️', i18n: 'catTabSolar' },
	{ id: 'algorithm', label: '跨行业算法',   emoji: '🔬', i18n: 'catTabAlgo' },
];

const SERIES = [
	{ id: 'all',            label: '全部系列',     emoji: '📚', i18n: 'seriesAll' },
	{ id: 'pvlib',          label: 'pvlib 库教程', emoji: '🔧', i18n: 'seriesPvlib' },
	{ id: 'solar-book',     label: '教材学习笔记', emoji: '📖', i18n: 'seriesBook' },
	{ id: 'cross-industry', label: '跨行业算法',   emoji: '🔬', i18n: 'seriesCross' },
	{ id: 'python-basics',  label: 'Python 基础',  emoji: '🐍', i18n: 'seriesPython' },
];
---

<!doctype html>
<html lang="zh">
	<head>
		<BaseHead title={`博客 — ${SITE_TITLE}`} description="Python 技术干货 + 光伏能源学习笔记" />
		<style>
			/* Category tabs */
			.cat-tabs {
				display: flex;
				gap: 0.6rem;
				margin-bottom: 2rem;
				flex-wrap: wrap;
			}
			.cat-tab {
				display: inline-flex;
				align-items: center;
				gap: 0.35rem;
				padding: 0.45rem 1.1rem;
				border-radius: 99px;
				border: 1px solid var(--border);
				background: var(--bg-card);
				color: var(--text-muted);
				font-size: 0.88rem;
				cursor: pointer;
				transition: all 0.18s;
				font-family: inherit;
			}
			.cat-tab:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.cat-tab.active {
				background: var(--accent);
				border-color: var(--accent);
				color: #1a1b26;
				font-weight: 700;
			}

			/* Category badge on card */
			.cat-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.1rem 0.55rem;
				border-radius: 4px;
				font-size: 0.75rem;
				font-weight: 600;
				margin-bottom: 0.5rem;
			}
			.cat-badge.python {
				background: rgba(61, 214, 140, 0.12);
				color: var(--accent);
				border: 1px solid rgba(61, 214, 140, 0.3);
			}
			.cat-badge.solar {
				background: rgba(245, 158, 11, 0.12);
				color: #f59e0b;
				border: 1px solid rgba(245, 158, 11, 0.3);
			}
			.cat-badge.algorithm {
				background: rgba(168, 85, 247, 0.12);
				color: #a855f7;
				border: 1px solid rgba(168, 85, 247, 0.3);
			}

			/* Series tabs */
			.series-tabs {
				display: flex;
				gap: 0.4rem;
				margin-bottom: 2rem;
				flex-wrap: wrap;
				align-items: center;
			}
			.series-label {
				color: var(--text-muted);
				font-size: 0.82rem;
				margin-right: 0.3rem;
			}
			.series-tab {
				display: inline-flex;
				align-items: center;
				gap: 0.25rem;
				padding: 0.3rem 0.8rem;
				border-radius: 99px;
				border: 1px solid var(--border);
				background: transparent;
				color: var(--text-muted);
				font-size: 0.78rem;
				cursor: pointer;
				transition: all 0.18s;
				font-family: inherit;
			}
			.series-tab:hover {
				border-color: var(--accent);
				color: var(--accent);
			}
			.series-tab.active {
				background: rgba(245, 158, 11, 0.15);
				border-color: var(--accent);
				color: var(--accent);
				font-weight: 600;
			}

			/* Badge row */
			.badge-row {
				display: flex;
				gap: 0.4rem;
				margin-bottom: 0.5rem;
				align-items: center;
			}

			/* Series badge on card */
			.series-badge {
				display: inline-flex;
				align-items: center;
				gap: 0.2rem;
				padding: 0.1rem 0.5rem;
				border-radius: 4px;
				font-size: 0.7rem;
				font-weight: 600;
			}
			.series-badge.pvlib {
				background: rgba(56, 189, 248, 0.12);
				color: #38bdf8;
				border: 1px solid rgba(56, 189, 248, 0.3);
			}
			.series-badge.solar-book {
				background: rgba(251, 146, 60, 0.12);
				color: #fb923c;
				border: 1px solid rgba(251, 146, 60, 0.3);
			}
			.series-badge.cross-industry {
				background: rgba(168, 85, 247, 0.12);
				color: #a855f7;
				border: 1px solid rgba(168, 85, 247, 0.3);
			}
			.series-badge.python-basics {
				background: rgba(61, 214, 140, 0.12);
				color: var(--accent);
				border: 1px solid rgba(61, 214, 140, 0.3);
			}

			/* Post list */
			.post-list { list-style: none; margin: 0; padding: 0; }
			.post-list li { margin-bottom: 1.2rem; }
			.post-list li[hidden] { display: none; }

			.post-card {
				display: block;
				background: var(--bg-card);
				border: 1px solid var(--border);
				border-radius: 10px;
				padding: 1.4rem 1.6rem;
				text-decoration: none;
				transition: border-color 0.18s, transform 0.18s;
			}
			.post-card:hover {
				border-color: var(--accent);
				transform: translateY(-2px);
				text-decoration: none;
			}
			.post-card h2 {
				margin: 0 0 0.4rem;
				font-size: 1.1rem;
				color: var(--text);
				border: none;
				padding: 0;
			}
			.post-card:hover h2 { color: var(--accent); }
			.post-card .meta {
				color: var(--text-muted);
				font-size: 0.82rem;
				margin-bottom: 0.5rem;
			}
			.post-card .excerpt {
				color: var(--text-muted);
				font-size: 0.9rem;
				margin: 0;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			/* Page header */
			.page-header {
				margin-bottom: 1.8rem;
				padding-bottom: 1.2rem;
				border-bottom: 1px solid var(--border);
			}
			.page-header h1 { margin: 0 0 0.3rem; font-size: 1.6rem; }
			.page-header p { color: var(--text-muted); font-size: 0.9rem; margin: 0; }

			.no-posts {
				text-align: center;
				color: var(--text-muted);
				padding: 3rem 0;
				display: none;
			}
			.no-posts.visible { display: block; }
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1 data-i18n="blogPageTitle">📖 博客</h1>
				<p data-i18n="blogPageDesc">Python 技术干货 · 光伏能源笔记 · 持续更新中</p>
			</div>

			<!-- Category tabs -->
			<div class="cat-tabs" id="catTabs">
				{CATEGORIES.map((c) => (
					<button
						class={`cat-tab${c.id === 'all' ? ' active' : ''}`}
						data-cat={c.id}
					>
						<span>{c.emoji}</span><span data-i18n={c.i18n}>{c.label}</span>
					</button>
				))}
			</div>

			<!-- Series tabs -->
			<div class="series-tabs" id="seriesTabs" style="display:flex">
				<span class="series-label" data-i18n="seriesLabel">系列：</span>
				{SERIES.map((s) => (
					<button
						class={`series-tab${s.id === 'all' ? ' active' : ''}`}
						data-series={s.id}
					>
						<span>{s.emoji}</span><span data-i18n={s.i18n}>{s.label}</span>
					</button>
				))}
			</div>

			<!-- Post list -->
			<ul class="post-list" id="postList">
				{posts.map((post) => (
					<li data-category={post.data.category} data-series={post.data.series || ''} data-lang={post.data.lang || 'zh'}>
						<a class="post-card" href={`/blog/${post.id}/`}>
							<div class="badge-row">
								<span class={`cat-badge ${post.data.category}`} data-i18n={post.data.category === 'python' ? 'catPython' : post.data.category === 'solar' ? 'catSolar' : 'catAlgo'}>
									{post.data.category === 'python' ? '🐍 Python' : post.data.category === 'solar' ? '☀️ 光伏' : '🔬 算法'}
								</span>
								{post.data.series && (
									<span class={`series-badge ${post.data.series}`}>
										{post.data.series === 'pvlib' ? '🔧 pvlib' : post.data.series === 'solar-book' ? '📖 教材' : post.data.series === 'cross-industry' ? '🔬 跨行业' : '🐍 基础'}
									</span>
								)}
							</div>
							<h2>{post.data.title}</h2>
							<p class="meta">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<p class="excerpt">{post.data.description}</p>
						</a>
					</li>
				))}
			</ul>

			<p class="no-posts" id="noPosts" data-i18n="noPosts">该分类暂无文章</p>
		</main>
		<Footer />

		<script>
			const catTabs = document.querySelectorAll<HTMLButtonElement>('.cat-tab');
			const seriesTabs = document.querySelectorAll<HTMLButtonElement>('.series-tab');
			const seriesBar = document.getElementById('seriesTabs')!;
			const items = document.querySelectorAll<HTMLLIElement>('#postList li');
			const noPostsEl = document.getElementById('noPosts')!;

			// 分类→系列映射：每个分类下显示哪些系列
			const CAT_SERIES: Record<string, string[]> = {
				'all':       ['pvlib', 'solar-book', 'cross-industry', 'python-basics'],
				'solar':     ['pvlib', 'solar-book'],
				'algorithm': ['cross-industry'],
				'python':    ['python-basics'],
			};

			function getCurrentLang(): string {
				try { return localStorage.getItem('preferred-lang') || 'zh'; } catch(e) { return 'zh'; }
			}

			let currentCat = 'all';
			let currentSeries = 'all';

			// 根据当前分类，显示/隐藏对应的系列标签
			function updateSeriesBar() {
				const allowed = CAT_SERIES[currentCat] || [];
				// 如果该分类只有 1 个系列，隐藏整个系列栏（没必要筛选）
				if (allowed.length <= 1) {
					seriesBar.style.display = 'none';
					currentSeries = 'all';
					return;
				}
				seriesBar.style.display = 'flex';
				seriesTabs.forEach((btn) => {
					const s = btn.dataset.series!;
					if (s === 'all') {
						btn.style.display = 'inline-flex';
					} else {
						btn.style.display = allowed.includes(s) ? 'inline-flex' : 'none';
					}
				});
				// 如果当前选的系列不在允许列表里，重置为全部
				if (currentSeries !== 'all' && !allowed.includes(currentSeries)) {
					currentSeries = 'all';
					seriesTabs.forEach((b) => b.classList.toggle('active', b.dataset.series === 'all'));
				}
			}

			function filter() {
				const lang = getCurrentLang();
				let visible = 0;
				items.forEach((li) => {
					const catMatch = currentCat === 'all' || li.dataset.category === currentCat;
					const seriesMatch = currentSeries === 'all' || li.dataset.series === currentSeries;
					const langMatch = li.dataset.lang === lang;
					const show = catMatch && seriesMatch && langMatch;
					li.hidden = !show;
					if (show) visible++;
				});
				noPostsEl.classList.toggle('visible', visible === 0);
			}

			catTabs.forEach((btn) => {
				btn.addEventListener('click', () => {
					currentCat = btn.dataset.cat!;
					catTabs.forEach((b) => b.classList.toggle('active', b.dataset.cat === currentCat));
					updateSeriesBar();
					filter();
				});
			});

			seriesTabs.forEach((btn) => {
				btn.addEventListener('click', () => {
					// "教材学习笔记" 跳转到专门的教材笔记页面
					if (btn.dataset.series === 'solar-book') {
						window.location.href = '/textbook/';
						return;
					}
					currentSeries = btn.dataset.series!;
					seriesTabs.forEach((b) => b.classList.toggle('active', b.dataset.series === currentSeries));
					filter();
				});
			});

			// 读取 URL 参数
			const params = new URLSearchParams(window.location.search);
			const urlCat = params.get('cat');
			const urlSeries = params.get('series');
			if (urlCat && ['python', 'solar', 'algorithm'].includes(urlCat)) {
				currentCat = urlCat;
				catTabs.forEach((b) => b.classList.toggle('active', b.dataset.cat === currentCat));
			}
			if (urlSeries && ['pvlib', 'solar-book', 'cross-industry', 'python-basics'].includes(urlSeries)) {
				currentSeries = urlSeries;
				seriesTabs.forEach((b) => b.classList.toggle('active', b.dataset.series === currentSeries));
			}
			updateSeriesBar();
			filter();

			// 监听语言切换
			window.addEventListener('langchange', () => filter());
		</script>
	</body>
</html>
