---
---
<div class="lang-switcher" id="langSwitcher">
  <button class="lang-btn" id="langBtn" aria-haspopup="true" aria-expanded="false">
    <span id="currentFlag">🇨🇳</span>
    <span id="currentLang">简体中文</span>
    <svg class="chevron" width="12" height="12" viewBox="0 0 12 12" fill="none">
      <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <ul class="lang-menu" id="langMenu" role="menu">
    <li role="menuitem" data-lang="en" data-flag="🇺🇸" data-label="English">
      🇺🇸 English
    </li>
    <li role="menuitem" data-lang="zh" data-flag="🇨🇳" data-label="简体中文" class="active">
      🇨🇳 简体中文
    </li>
    <li role="menuitem" data-lang="ja" data-flag="🇯🇵" data-label="日本語">
      🇯🇵 日本語
    </li>
  </ul>
</div>

<style>
.lang-switcher {
  position: relative;
}

.lang-btn {
  display: flex;
  align-items: center;
  gap: 6px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 6px 10px;
  color: var(--text);
  cursor: pointer;
  font-size: 0.85rem;
  font-family: inherit;
  transition: border-color 0.2s, background 0.2s;
  white-space: nowrap;
}
.lang-btn:hover {
  border-color: var(--accent);
  background: var(--tag-bg);
}

.chevron {
  opacity: 0.6;
  transition: transform 0.2s;
}
.lang-switcher.open .chevron {
  transform: rotate(180deg);
}

.lang-menu {
  display: none;
  position: absolute;
  right: 0;
  top: calc(100% + 6px);
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  list-style: none;
  margin: 0;
  padding: 6px;
  min-width: 140px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.4);
  z-index: 999;
}
.lang-switcher.open .lang-menu {
  display: block;
}

.lang-menu li {
  padding: 8px 12px;
  border-radius: 6px;
  cursor: pointer;
  font-size: 0.88rem;
  color: var(--text-muted);
  transition: background 0.15s, color 0.15s;
  margin-bottom: 1px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.lang-menu li:hover {
  background: var(--tag-bg);
  color: var(--text);
}
.lang-menu li.active {
  color: var(--accent);
  background: var(--tag-bg);
}
.lang-menu li.active::after {
  content: '✓';
  margin-left: auto;
  font-size: 0.8rem;
}
</style>

<script>
const TRANSLATIONS: Record<string, Record<string, string>> = {
  en: {
    siteTitle: '🐍 Python Ship',
    siteTagline: 'Daily Python Knowledge Base — Tips · Tutorials · Quick Cards',
    navHome: 'Home',
    navBlog: 'Blog',
    navGitHub: 'GitHub',
    heroTitle: '🐍 Python Ship',
    heroTagline: 'Daily Python Knowledge Base',
    heroSub: 'Auto-published every night at 10 PM — Tips · Tutorials · Quick Cards',
    recentPosts: 'Recent Posts',
    readMore: 'Read more →',
    footerText: '🐍 Python Ship · Daily Python Knowledge Base · Auto-updated',
  },
  zh: {
    siteTitle: '🐍 Python Ship',
    siteTagline: '每日 Python 知识库 — 技术干货 · 教程 · 知识卡片',
    navHome: '首页',
    navBlog: '博客',
    navGitHub: 'GitHub',
    heroTitle: '🐍 Python Ship',
    heroTagline: '每日 Python 知识库',
    heroSub: '每晚 22:00 自动发布 — 技术干货 · 教程型 · 知识卡片',
    recentPosts: '最近文章',
    readMore: '阅读全文 →',
    footerText: '🐍 Python Ship · 每日 Python 知识库 · 自动更新',
  },
  ja: {
    siteTitle: '🐍 Python Ship',
    siteTagline: '毎日 Python ナレッジベース — 技術 · チュートリアル · カード',
    navHome: 'ホーム',
    navBlog: 'ブログ',
    navGitHub: 'GitHub',
    heroTitle: '🐍 Python Ship',
    heroTagline: '毎日 Python ナレッジベース',
    heroSub: '毎晩 22:00 自動公開 — 技術情報 · チュートリアル · 知識カード',
    recentPosts: '最近の記事',
    readMore: '続きを読む →',
    footerText: '🐍 Python Ship · 毎日 Python ナレッジベース · 自動更新',
  },
};

function applyLang(lang: string) {
  const t = TRANSLATIONS[lang] || TRANSLATIONS.zh;
  document.querySelectorAll('[data-i18n]').forEach((el) => {
    const key = (el as HTMLElement).dataset.i18n!;
    if (t[key]) el.textContent = t[key];
  });
  try { localStorage.setItem('preferred-lang', lang); } catch(e) {}
}

function initSwitcher() {
  const switcher = document.getElementById('langSwitcher');
  const btn = document.getElementById('langBtn');
  const menu = document.getElementById('langMenu');
  const currentFlag = document.getElementById('currentFlag');
  const currentLang = document.getElementById('currentLang');
  if (!switcher || !btn || !menu) return;

  let savedLang = 'zh';
  try { savedLang = localStorage.getItem('preferred-lang') || 'zh'; } catch(e) {}
  const savedItem = menu.querySelector(`[data-lang="${savedLang}"]`) as HTMLElement;
  if (savedItem && currentFlag && currentLang) {
    currentFlag.textContent = savedItem.dataset.flag || '🇨🇳';
    currentLang.textContent = savedItem.dataset.label || '简体中文';
    menu.querySelectorAll('li').forEach(li => li.classList.remove('active'));
    savedItem.classList.add('active');
  }
  applyLang(savedLang);

  btn.addEventListener('click', (e) => {
    e.stopPropagation();
    switcher.classList.toggle('open');
    btn.setAttribute('aria-expanded', String(switcher.classList.contains('open')));
  });

  menu.querySelectorAll('li').forEach((item) => {
    item.addEventListener('click', () => {
      const lang = (item as HTMLElement).dataset.lang!;
      const flag = (item as HTMLElement).dataset.flag!;
      const label = (item as HTMLElement).dataset.label!;
      if (currentFlag) currentFlag.textContent = flag;
      if (currentLang) currentLang.textContent = label;
      menu.querySelectorAll('li').forEach(li => li.classList.remove('active'));
      item.classList.add('active');
      switcher.classList.remove('open');
      applyLang(lang);
    });
  });

  document.addEventListener('click', () => {
    switcher.classList.remove('open');
    btn.setAttribute('aria-expanded', 'false');
  });
}

document.addEventListener('DOMContentLoaded', initSwitcher);
</script>
